# Production Environment Configuration
ENV=production

# JWT Authentication Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=generate-a-secure-64-character-hex-string-here

# API Administrative Credentials
API_ADMIN_USER=admin
API_ADMIN_PASSWORD=set-a-strong-custom-password-here

# Database Configuration
# Keep this as is for standard Docker Compose persistent storage
DB_PATH=/app/data/persistent/predictions.db
